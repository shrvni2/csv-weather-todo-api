# Ignore operating system files
.DS_Store
Thumbs.db

# Ignore IDE files
.vscode/
.idea/
*.iml

# Ignore byte-compiled Python files
*.pyc
*.pyo
*.pyd

# Ignore Python packages
__pycache__/

# Ignore virtual environment files
env/
venv/
*.egg-info

# Ignore requirements files
requirements.txt

# Ignore log files
*.log

# Ignore CSV and JSON files generated by the application
output.json
output.csv

# Ignore Flask and API related files
instance/
*.pid

# Ignore todo list and weather data files
todo_list.json
weather_data.json

# Ignore Git files
.gitignore
.gitattributes

